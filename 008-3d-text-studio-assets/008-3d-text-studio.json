{
  "id": "008-3d-text-studio",
  "name": "3D Text Studio",
  "title": "立体字工作台",
  "entry": "008-3d-text-studio.html",
  "style": "008-3d-text-studio-assets/style.css",
  "script": "008-3d-text-studio-assets/app.jsx",
  "assets": "008-3d-text-studio-assets/",
  "description": "基于 React、Three.js 和 opentype.js 的中文立体字设计工作台，支持预设中文字体、本地字体拖拽、材质库、逐字语义材质建议、入场动画、粒子、背景调节、PNG 与 GIF 导出。",
  "version": "1.0.0",
  "features": [
    "React 控制面板与 Three.js 3D 文字画布",
    "预设中文字体与本地 .ttf / .otf / .woff 拖拽加载",
    "16 组常用材质预设与逐字材质分配",
    "中文字符语义分析与字效建议",
    "挤出深度、倒角、字距、描边和阴影调节",
    "自动旋转、呼吸、入场动画、流光、视差、故障和粒子效果",
    "透明、纯色、渐变背景与抠像预设",
    "PNG 静帧导出与 GIF 动画导出"
  ],
  "scripts": [
    "008-3d-text-studio-assets/char-data.js",
    "008-3d-text-studio-assets/materials.js",
    "008-3d-text-studio-assets/scene.js",
    "008-3d-text-studio-assets/app.jsx"
  ],
  "dependencies": [
    {
      "name": "React",
      "url": "https://unpkg.com/react@18.3.1/umd/react.development.js"
    },
    {
      "name": "React DOM",
      "url": "https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js"
    },
    {
      "name": "Babel Standalone",
      "url": "https://unpkg.com/@babel/standalone@7.29.0/babel.min.js"
    },
    {
      "name": "Three.js",
      "url": "https://cdn.jsdelivr.net/npm/three@0.147.0/build/three.min.js"
    },
    {
      "name": "opentype.js",
      "url": "https://cdn.jsdelivr.net/npm/opentype.js@1.3.4/dist/opentype.min.js"
    },
    {
      "name": "gif.js",
      "url": "https://cdn.jsdelivr.net/npm/gif.js@0.2.0/dist/gif.js"
    }
  ],
  "controls": {
    "keyboard": [
      "R reset camera",
      "Space toggle animation",
      "Tab toggle pure visual mode",
      "Esc exit pure visual mode"
    ],
    "exports": [
      "PNG",
      "GIF"
    ]
  }
}
